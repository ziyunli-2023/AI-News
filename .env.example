# X (Twitter) API — only Bearer Token needed for reading public timelines
# Get from: https://developer.twitter.com/en/portal/dashboard
# Leave empty to skip tweet monitoring
X_BEARER_TOKEN=your_bearer_token_here

# Email notifications (Gmail SMTP)
# App Password: Google Account → Security → 2-Step Verification → App Passwords
# Leave empty to disable email notifications
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
EMAIL_RECIPIENT=where_to_receive@example.com

# DeepSeek API key (for auto-translation of English titles/summaries to Chinese)
# Get from: https://platform.deepseek.com/api_keys
# Leave empty to disable translation
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# Web dashboard port (default 8000)
WEB_PORT=8000
